{
  "name": "music-library",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "npm run typecheck && vite build && npm run build:service-worker",
    "build:service-worker": "tsx scripts/build-service-worker.ts",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.worker.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:audio": "cd services/audio-converter && python3 -m unittest discover -s tests -v",
    "test:watch": "vitest",
    "import:appsheet": "tsx scripts/appsheet-import.ts",
    "db:load-local": "tsx scripts/load-local-db.ts",
    "media:upload": "tsx scripts/upload-r2.ts",
    "media:plan-audio": "tsx scripts/plan-audio-integration.ts",
    "media:plan-scan-fingerprints": "tsx scripts/plan-scan-fingerprint-backfill.ts",
    "media:recover-scan-originals": "tsx scripts/scan-original-recovery.ts",
    "media:review-scan-originals": "tsx scripts/scan-original-review-server.ts",
    "media:import-scan-review": "tsx scripts/scan-original-review-import.ts",
    "media:pdf-scan-review": "tsx scripts/scan-original-confirmed-pdf.ts",
    "media:review-unassigned-drive": "tsx scripts/scan-original-unassigned-drive-review.ts",
    "media:apply-unassigned-drive-feedback": "tsx scripts/scan-original-unassigned-drive-feedback.ts",
    "media:swap-scan-originals": "tsx scripts/scan-original-swap-executor.ts",
    "media:backfill-scan-fingerprints": "tsx scripts/scan-fingerprint-backfill-executor.ts",
    "media:integrate-audio": "tsx scripts/audio-integration-executor.ts",
    "ops:processor-snapshot": "tsx scripts/processor-ops-snapshot.ts"
  },
  "dependencies": {
    "dexie": "4.4.4",
    "hono": "4.12.29",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@cloudflare/workers-types": "5.20260712.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "read-excel-file": "9.3.1",
    "sharp": "0.34.5",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
